{
  "name": "@facturin/sdk",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --declaration --outDir dist && bun build src/index.ts --outdir=dist --target=bun --format=esm",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "bun test"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "eslint": "^10.1.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.1"
  }
}
