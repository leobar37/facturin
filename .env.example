# Database
DATABASE_URL=postgresql://facturin:facturin@localhost:5432/facturin

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6380

# Super Admin (for web login)
SUPER_ADMIN_EMAIL=admin@facturin.local
SUPER_ADMIN_PASSWORD_HASH=$2b$10$example_hash_here

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# SUNAT Environment: mock | beta | production
SUNAT_ENVIRONMENT=mock
MOCK_SUNAT_PORT=3099

# SUNAT (OSE mode - only needed for beta/production)
OSE_SUNAT_USERNAME=your-ose-username
OSE_SUNAT_PASSWORD=your-ose-password

# Instance
INSTANCE_NAME=Facturin
INSTANCE_URL=http://localhost:3102

# Encryption (must be exactly 32 characters for AES-256)
ENCRYPTION_KEY=dev-encryption-key-32-chars-long!!
